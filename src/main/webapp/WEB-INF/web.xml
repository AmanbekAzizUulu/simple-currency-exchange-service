<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" version="4.0">

	<welcome-file-list>
		<welcome-file>index.html</welcome-file>
	</welcome-file-list>
	<!-- Servlet Declaration -->
	<!-- 				 	 -->
	<servlet>
		<servlet-name>CurrenciesServlet</servlet-name>
		<servlet-class>com.dandaev.edu.controller.CurrenciesServlet</servlet-class>
	</servlet>

	<servlet>
		<servlet-name>CurrencyServlet</servlet-name>
		<servlet-class>com.dandaev.edu.controller.CurrencyServlet</servlet-class>
	</servlet>

	<servlet>
		<servlet-name>ExchangeRatesServlet</servlet-name>
		<servlet-class>com.dandaev.edu.controller.ExchangeRatesServlet</servlet-class>
	</servlet>

	<servlet>
		<servlet-name>ExchangeRateServlet</servlet-name>
		<servlet-class>com.dandaev.edu.controller.ExchangeRateServlet</servlet-class>
	</servlet>

	<servlet>
		<servlet-name>ExchangeServlet</servlet-name>
		<servlet-class>com.dandaev.edu.controller.ExchangeServlet</servlet-class>
	</servlet>

	<servlet>
		<servlet-name>GreeterServlet</servlet-name>
		<servlet-class>com.dandaev.edu.controller.GreeterServlet</servlet-class>
	</servlet>

	<!-- Servlet Mapping -->
	<!-- 				 -->
	<servlet-mapping>
		<servlet-name>CurrenciesServlet</servlet-name>
		<url-pattern>/currencies</url-pattern>
	</servlet-mapping>

	<servlet-mapping>
		<servlet-name>CurrencyServlet</servlet-name>
		<url-pattern>/currency/*</url-pattern>
	</servlet-mapping>

	<servlet-mapping>
		<servlet-name>ExchangeRatesServlet</servlet-name>
		<url-pattern>/exchangeRates</url-pattern>
	</servlet-mapping>

	<servlet-mapping>
		<servlet-name>ExchangeRateServlet</servlet-name>
		<url-pattern>/exchangeRate/*</url-pattern>
	</servlet-mapping>

	<servlet-mapping>
		<servlet-name>ExchangeServlet</servlet-name>
		<url-pattern>/exchange</url-pattern>
	</servlet-mapping>

	<servlet-mapping>
		<servlet-name>GreeterServlet</servlet-name>
		<url-pattern>/info</url-pattern>
	</servlet-mapping>

	<!-- Listeners Declaration -->
	<!-- 				 	   -->
	<listener>
		<listener-class>com.dandaev.edu.listener.AppContextListener</listener-class>
	</listener>

	<!-- Filter Declaration -->
	<!-- 				    -->
	<filter>
		<filter-name>ExceptionHandlingFilter</filter-name>
		<filter-class>com.dandaev.edu.filter.ExceptionHandlingFilter</filter-class>
	</filter>

	<!-- Filter Mapping -->
	<!-- 				-->
	<filter-mapping>
		<filter-name>ExceptionHandlingFilter</filter-name>
		<url-pattern>/*</url-pattern>
	</filter-mapping>

</web-app>
